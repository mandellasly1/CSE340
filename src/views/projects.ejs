<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <p>Here are the next upcoming service projects:</p>

  <div class="projects-container">
    <% projects.forEach(project => { %>
      <div class="project-box 
        <% if (project.organization_name === 'BrightFuture Builders') { %> brightfuture <% } %>
        <% if (project.organization_name === 'GreenHarvest Growers') { %> greenharvest <% } %>
        <% if (project.organization_name === 'UnityServe Volunteers') { %> unityserve <% } %>">
        
        <!-- Project title now links to project details -->
        <h3>
          <a href="/project/<%= project.project_id %>"><%= project.title %></a>
        </h3>

        <!-- Date (use project.date instead of project.project_date if that’s your column name) -->
        <p>Date: <%= new Date(project.date).toDateString() %></p>

        <!-- Organization name now links to organization details -->
        <p>
          <em>
            <a href="/organization/<%= project.organization_id %>">
              <%= project.organization_name %>
            </a>
          </em>
        </p>
      </div>
    <% }); %>
  </div>
</main>
<%- include('partials/footer') %>
