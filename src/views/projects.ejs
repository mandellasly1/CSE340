<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>
  <p>Here are a few of our service projects:</p>

  <div class="projects-container">
    <% projects.forEach(project => { %>
      <div class="project-box 
        <% if (project.organization_name === 'BrightFuture Builders') { %> brightfuture <% } %>
        <% if (project.organization_name === 'GreenHarvest Growers') { %> greenharvest <% } %>
        <% if (project.organization_name === 'UnityServe Volunteers') { %> unityserve <% } %>">
        
        <h3><%= project.title %></h3>
        <p>Date: <%= project.project_date.toDateString() %></p>
        <p><em><%= project.organization_name %></em></p>
      </div>
    <% }); %>
  </div>
</main>
<%- include('partials/footer') %>
